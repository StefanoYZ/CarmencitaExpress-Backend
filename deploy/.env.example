# Variables compartidas para deploy/docker-compose.yml en el Droplet.
# Copia este archivo como ".env" (mismo directorio que docker-compose.yml) y
# completa los valores reales. NUNCA subas ".env" al repositorio.
#
# En CI/CD, GitHub Actions sobreescribe este archivo en el Droplet con el
# contenido del secret ENV_FILE (ver .github/workflows/deploy.yml).

# ---------- PostgreSQL ----------
POSTGRES_USER=carmencita
POSTGRES_PASSWORD=cambia_esta_clave_larga_y_aleatoria
POSTGRES_DB=carmencita_db

# ---------- Backend (FastAPI) ----------
APP_NAME=Carmencita Smart System
# Dominio publico del Droplet. Con el reverse proxy de nginx el navegador nunca
# sale de este origen, pero deja el valor real por si accedes al backend
# directamente (debug, curl) o durante la transicion sin proxy.
CORS_ORIGINS=https://tu-dominio-o-ip-del-droplet

SUNAT_ENV=beta
SUNAT_ALLOW_REAL_EMISSION=false

# Debe coincidir EXACTO con CLIENT_TOKEN de la seccion Lycet mas abajo.
LYCET_CLIENT_TOKEN=token_privado_compartido_entre_backend_y_lycet

MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token

RENIEC_API_URL=https://api-reniec.example.com
RENIEC_API_TOKEN=your_reniec_token

SECRET_KEY=cambia_esta_clave_jwt_larga_y_aleatoria
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@carmencita.com
DEFAULT_ADMIN_PASSWORD=cambia_esta_password_en_produccion

# LLM (opcional; sin clave el asistente usa respuestas por reglas)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
ASSISTANT_LLM_ENABLED=true

# Busqueda web para recojo externo (opcional)
SEARCH_API_KEY=
SEARCH_API_URL=https://google.serper.dev/search

# ---------- Frontend (Vite, se hornea en build time) ----------
# Relativo: nginx enruta /api/v1 al backend en el mismo origen. No cambiar
# salvo que definas el backend en un dominio distinto (no recomendado).
VITE_API_BASE_URL=/api/v1

# ---------- Lycet (SUNAT beta, PHP/Symfony) ----------
LYCET_APP_SECRET=cambia_esta_clave_symfony_larga
# Debe coincidir con LYCET_CLIENT_TOKEN de la seccion Backend.
# (repetido aqui por claridad; usa el MISMO valor en ambas variables)
LYCET_SOL_USER=RUC_USUARIO_SOL
LYCET_SOL_PASS=clave_sol
# Certificado .pem del emisor, codificado en base64 (ver deploy/README.md).
LYCET_CERTIFICATE_BASE64=
LYCET_LOGO_BASE64=
LYCET_FE_URL=https://e-beta.sunat.gob.pe/ol-ti-itcpfegem-beta/billService
LYCET_RE_URL=https://e-beta.sunat.gob.pe/ol-ti-itemision-otroscpe-gem-beta/billService
LYCET_GUIA_URL=https://e-beta.sunat.gob.pe/ol-ti-itemision-guia-gem-beta/billService
LYCET_AUTH_URL=https://gre-test.nubefact.com/v1
LYCET_API_URL_GUIA=https://gre-test.nubefact.com/v1
LYCET_CLIENT_ID=
LYCET_CLIENT_SECRET=
