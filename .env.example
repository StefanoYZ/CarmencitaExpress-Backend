# Backend FastAPI - Carmencita Express
# Copia este archivo como .env para desarrollo local.
# En despliegue, configura estas variables directamente en Render.
# No subas credenciales reales al repositorio.

# App
APP_NAME=Carmencita Smart System
API_PREFIX=/api/v1

# CORS
# Local:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Despliegue Render + Netlify:
# CORS_ORIGINS=https://tu-sitio.netlify.app
# Si necesitas ambos:
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://tu-sitio.netlify.app

# Base de datos PostgreSQL
# Local:
DATABASE_URL=postgresql+psycopg2://postgres:TU_PASSWORD@localhost:5432/carmencita_db
# Despliegue Render PostgreSQL:
# Usa la Internal Database URL si backend y BD estan en Render.
# Cambia postgresql:// por postgresql+psycopg2://
# DATABASE_URL=postgresql+psycopg2://usuario:password@host-interno:5432/carmencita_db
# No reutilices una URL de una base eliminada o recreada: el host dpg-* cambia.
# Si la base y el backend estan en regiones distintas, usa la External Database URL.

# SUNAT / Lycet
SUNAT_ENV=beta
SUNAT_PROVIDER=lycet
SUNAT_ALLOW_REAL_EMISSION=false
# Local si Lycet esta expuesto en tu maquina:
LYCET_API_URL=http://localhost:8001
# Docker Compose si backend y Lycet estan en la misma red:
# LYCET_API_URL=http://lycet:8001
# Despliegue si Lycet esta en otro servicio:
# LYCET_API_URL=https://tu-servicio-lycet.onrender.com
LYCET_CLIENT_TOKEN=your_lycet_token

# Mercado Pago
MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token

# RENIEC
RENIEC_API_URL=https://api-reniec.example.com
RENIEC_API_TOKEN=your_reniec_token

# Seguridad interna / JWT
SECRET_KEY=change_me_for_a_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@carmencita.com
DEFAULT_ADMIN_PASSWORD=change_me_for_production
